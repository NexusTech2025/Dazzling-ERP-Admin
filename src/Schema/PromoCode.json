{
  "entity": "PromoCode",
  "description": "Promotional codes offering discounts on courses or packages.",
  "fields": [
    { "name": "promo_id", "type": "string", "isPrimary": true },
    { "name": "code", "type": "string", "isUnique": true, "required": true },
    { "name": "entity_type", "type": "enum", "values": ["course", "package"] },
    { "name": "entity_id", "type": "string" },
    { "name": "discount_type", "type": "enum", "values": ["percentage", "amount"] },
    { "name": "discount_value", "type": "number" },
    { "name": "max_usage", "type": "integer" },
    { "name": "valid_from", "type": "date" },
    { "name": "valid_until", "type": "date" },
    { "name": "status", "type": "enum", "values": ["active", "expired", "disabled"], "default": "active" }
  ]
}