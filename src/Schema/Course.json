{
  "entity": "Course",
  "description": "Individual subjects or academic offerings provided by the institute. Supports board-specific pricing and language mediums.",
  "fields": [
    { "name": "course_id", "type": "string", "isPrimary": true },
    { "name": "segment_id", "type": "string", "isForeignKey": true, "references": "CourseType.segment_id" },
    { 
      "name": "entity_type", 
      "type": "enum", 
      "values": ["subject", "course"], 
      "description": "'subject' for strict curriculum items, 'course' for flexible/skill-based programs."
    },
    { "name": "name", "type": "string", "required": true },
    { "name": "short_code", "type": "string", "isUnique": true },
    { 
      "name": "language_medium", 
      "type": "enum", 
      "values": ["English", "Hindi", "Urdu"], 
      "required": true 
    },
    { "name": "description", "type": "string" },
    { "name": "duration_value", "type": "integer" },
    { "name": "duration_unit", "type": "enum", "values": ["months", "days", "weeks"], "default": "months" },
    { "name": "base_fee", "type": "number", "required": true, "description": "Fee varies by board/medium." },
    { "name": "default_installment_count", "type": "integer", "default": 1 },
    { "name": "status", "type": "enum", "values": ["active", "inactive"], "default": "active" },
    { 
      "name": "metadata", 
      "type": "json", 
      "description": "For subjects: {class, board}. For courses: {min_class, max_class}." 
    }
  ],
  "relations": [
    { "type": "N:1", "target": "CourseType", "field": "segment_id" }
  ]
}