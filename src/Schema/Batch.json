{
  "entity": "Batch",
  "description": "Operational instances of courses with specific timing, teachers, and student capacity.",
  "fields": [
    { "name": "batch_id", "type": "string", "isPrimary": true },
    { "name": "item_id", "type": "string", "isForeignKey": true, "references": "Course.course_id", "description": "The course this batch belongs to." },
    { "name": "teacher_id", "type": "string", "isForeignKey": true, "references": "Teacher.teacher_id" },
    { "name": "branch_id", "type": "string", "isForeignKey": true, "references": "Branch.branch_id" },
    { "name": "batch_name", "type": "string", "required": true },
    { "name": "start_date", "type": "date" },
    { "name": "end_date", "type": "date" },
    { "name": "capacity", "type": "integer", "default": 30 },
    { "name": "status", "type": "enum", "values": ["active", "completed", "cancelled"], "default": "active" },
    { "name": "schedule", "type": "json", "description": "Stored as { days_of_week: [], start_time: '', end_time: '' }" }
  ],
  "relations": [
    { "type": "N:1", "target": "Course", "field": "item_id" },
    { "type": "N:1", "target": "Teacher", "field": "teacher_id" },
    { "type": "N:1", "target": "Branch", "field": "branch_id" }
  ]
}