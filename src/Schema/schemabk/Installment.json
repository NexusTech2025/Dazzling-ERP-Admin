{
  "entity": "Installment",
  "description": "Breakdown of the final fee into dated payment requests.",
  "fields": [
    { "name": "installment_id", "type": "string", "isPrimary": true },
    { "name": "student_fee_id", "type": "string", "isForeignKey": true, "references": "StudentFeeAccount.student_fee_id" },
    { "name": "installment_number", "type": "integer" },
    { "name": "due_amount", "type": "number", "required": true },
    { "name": "paid_amount", "type": "number", "default": 0 },
    { "name": "late_fee_amount", "type": "number", "default": 0 },
    { "name": "due_date", "type": "date", "required": true },
    { "name": "status", "type": "enum", "values": ["pending", "partially_paid", "paid", "overdue"], "default": "pending" }
  ],
  "relations": [
    { "type": "N:1", "target": "StudentFeeAccount", "field": "student_fee_id" }
  ]
}