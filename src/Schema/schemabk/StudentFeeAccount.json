{
  "entity": "StudentFeeAccount",
  "description": "The personal financial ledger for a student's enrollment.",
  "fields": [
    { "name": "student_fee_id", "type": "string", "isPrimary": true },
    { "name": "enrollment_id", "type": "string", "isForeignKey": true, "references": "Enrollment.enrollment_id" },
    { "name": "fee_plan_id", "type": "string", "isForeignKey": true, "references": "FeePlan.fee_plan_id" },
    { "name": "total_fee", "type": "number", "description": "Base fee at time of enrollment" },
    { "name": "discount", "type": "number", "default": 0 },
    { "name": "adjustment_type", "type": "enum", "values": ["scholarship", "coupon", "referral", "manual_override", "none"] },
    { "name": "coupon_code", "type": "string" },
    { "name": "final_fee", "type": "number", "description": "Legally binding amount (total - discount)" },
    { "name": "amount_paid", "type": "number", "default": 0 },
    { "name": "balance_due", "type": "number" },
    { "name": "is_overdue", "type": "boolean", "default": false },
    { "name": "penalty_amount", "type": "number", "default": 0 },
    { "name": "next_due_date", "type": "date" },
    { "name": "status", "type": "enum", "values": ["active", "completed", "defaulted", "refunded"], "default": "active" },
    { "name": "remarks", "type": "string" },
    { "name": "created_by", "type": "string" },
    { "name": "created_at", "type": "datetime" },
    { "name": "updated_at", "type": "datetime" }
  ],
  "relations": [
    { "type": "1:1", "target": "Enrollment", "field": "enrollment_id" },
    { "type": "N:1", "target": "FeePlan", "field": "fee_plan_id" }
  ]
}