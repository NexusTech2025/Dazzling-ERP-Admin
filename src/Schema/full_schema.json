    "Staff": {
      "tables": {
        "TeacherAttendance": {
          "primaryKey": "attendance_id",
          "columns": {
            "attendance_id": {
              "type": "string",
              "required": false,
              "unique": true,
              "description": "Unique identifier for each attendance record. Typically a UUID or structured ID used to uniquely track each attendance entry."
            },
            "teacher_id": {
              "type": "string",
              "required": true,
              "unique": false,
              "description": "Reference to the teacher whose attendance is being recorded. Links this record to the Teacher entity."
            },
            "attendance_date": {
              "type": "date",
              "required": true,
              "unique": false,
              "description": "The specific calendar date for which attendance is recorded. Only one record per teacher per date should exist."
            },
            "status": {
              "type": "enum",
              "required": true,
              "unique": false,
              "enum": [
                "present",
                "absent",
                "leave",
                "half_day"
              ],
              "description": "Indicates the attendance status of the teacher for the given date. Used directly in salary calculations and attendance reporting."
            },
            "check_in_time": {
              "type": "datetime",
              "required": false,
              "unique": false,
              "description": "Timestamp when the teacher checked in for the day. Useful for tracking punctuality and working duration."
            },
            "check_out_time": {
              "type": "datetime",
              "required": false,
              "unique": false,
              "description": "Timestamp when the teacher checked out. Helps determine total working hours and verify attendance accuracy."
            },
            "working_hours": {
              "type": "number",
              "required": false,
              "unique": false,
              "description": "Total number of hours worked by the teacher on the given day. Can be calculated from check-in and check-out or manually entered for flexibility."
            },
            "is_paid_leave": {
              "type": "boolean",
              "required": false,
              "unique": false,
              "default": false,
              "description": "Indicates whether a leave day is considered paid or unpaid. Critical for accurate payroll calculations and leave policy enforcement."
            },
            "attendance_source": {
              "type": "enum",
              "required": false,
              "unique": false,
              "enum": [
                "manual",
                "biometric",
                "system"
              ],
              "description": "Specifies how the attendance was recorded. Enables tracking of manual entries versus automated systems like biometric devices."
            },
            "notes": {
              "type": "string",
              "required": false,
              "unique": false,
              "description": "Optional remarks or comments related to the attendance entry, such as reasons for leave, late arrival, or special conditions."
            },
            "marked_by": {
              "type": "string",
              "required": false,
              "unique": false,
              "description": "Identifier of the admin or system user who recorded or updated the attendance. Useful for accountability and audit tracking."
            },
            "created_at": {
              "type": "datetime",
              "required": false,
              "unique": false,
              "description": "Timestamp when the attendance record was initially created in the system."
            },
            "updated_at": {
              "type": "datetime",
              "required": false,
              "unique": false,
              "description": "Timestamp of the most recent update to the attendance record. Ensures traceability of modifications."
            }
