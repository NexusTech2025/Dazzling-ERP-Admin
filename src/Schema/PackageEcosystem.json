{
  "domain": "Package & Offering Bundles",
  "description": "Consolidated schema for packages, course mappings, perks, and promotional offers.",
  "entities": {
    "Package": {
      "description": "Bundled academic offerings where multiple courses are sold as a single program.",
      "fields": [
        { "name": "package_id", "type": "string", "isPrimary": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "description", "type": "string" },
        { "name": "target_class", "type": "string" },
        { "name": "board", "type": "string" },
        { "name": "month", "type": "integer", "description": "Duration in months" },
        { "name": "package_fee", "type": "number", "required": true },
        { "name": "discount_percent", "type": "number" },
        { "name": "status", "type": "enum", "values": ["active", "inactive", "draft"], "default": "active" }
      ]
    },
    "PackageCourse": {
      "description": "Mapping table defining which courses belong to a package.",
      "fields": [
        { "name": "package_course_id", "type": "string", "isPrimary": true },
        { "name": "package_id", "type": "string", "isForeignKey": true, "references": "Package.package_id" },
        { "name": "course_id", "type": "string", "isForeignKey": true, "references": "Course.course_id" }
      ],
      "relations": [
        { "type": "N:1", "target": "Package", "field": "package_id" },
        { "type": "N:1", "target": "Course", "field": "course_id" }
      ]
    },
    "PackagePerk": {
      "description": "Value-added benefits included in a package.",
      "fields": [
        { "name": "perk_id", "type": "string", "isPrimary": true },
        { "name": "package_id", "type": "string", "isForeignKey": true, "references": "Package.package_id" },
        { "name": "perk_title", "type": "string", "required": true },
        { "name": "perk_description", "type": "string" },
        { "name": "icon", "type": "string" },
        { "name": "display_order", "type": "integer" }
      ],
      "relations": [
        { "type": "N:1", "target": "Package", "field": "package_id" }
      ]
    },
    "PromoCode": {
      "description": "Promotional codes offering discounts on courses or packages.",
      "fields": [
        { "name": "promo_id", "type": "string", "isPrimary": true },
        { "name": "code", "type": "string", "isUnique": true, "required": true },
        { "name": "entity_type", "type": "enum", "values": ["course", "package"] },
        { "name": "entity_id", "type": "string" },
        { "name": "discount_type", "type": "enum", "values": ["percentage", "amount"] },
        { "name": "discount_value", "type": "number" },
        { "name": "max_usage", "type": "integer" },
        { "name": "valid_from", "type": "date" },
        { "name": "valid_until", "type": "date" },
        { "name": "status", "type": "enum", "values": ["active", "expired", "disabled"], "default": "active" }
      ]
    }
  }
}
